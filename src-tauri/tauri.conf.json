{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cmmuu Music",
  "version": "0.1.0",
  "identifier": "cn.cmmuu.music",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Cmmuu Music",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https: data: asset: http://asset.localhost; media-src 'self' https: asset: http://asset.localhost; connect-src 'self' https: ipc: http://ipc.localhost",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "copyright": "© 2026 CmmuuMusic",
    "shortDescription": "Cmmuu Music — 跨平台音乐播放器",
    "longDescription": "Cmmuu Music 基于 Tauri v2 + Vue 3 的跨平台桌面音乐播放器，通过合规插件获取音乐数据。"
  },
  "plugins": {}
}
